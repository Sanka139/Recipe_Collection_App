<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark_main">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/img4" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add New Recipe"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="32dp"
                android:gravity="center"/>

            <EditText
                android:id="@+id/etRecipeName"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:hint="Recipe Name"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_glass_edittext"
                android:paddingStart="20dp"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etRecipeTime"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:hint="Cooking Time (e.g. 30 Mins)"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_glass_edittext"
                android:paddingStart="20dp"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etRecipeIngredients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="120dp"
                android:hint="Ingredients"
                android:gravity="top"
                android:padding="20dp"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_glass_edittext"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etRecipeSteps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="150dp"
                android:hint="Instructions / Steps"
                android:gravity="top"
                android:padding="20dp"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_glass_edittext"
                android:layout_marginBottom="16dp"/>

            <ImageView
                android:id="@+id/ivRecipeImage"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="16dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_glass_edittext" />

            <Button
                android:id="@+id/btnAddImage"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="ADD IMAGE"
                android:backgroundTint="#80FFFFFF"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"
                app:cornerRadius="20dp"/>

            <EditText
                android:id="@+id/etRecipeComment"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:hint="Additional Notes"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_glass_edittext"
                android:paddingStart="20dp"
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/btnAddRecipe"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="SAVE RECIPE"
                android:backgroundTint="@color/accent_orange"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="16sp"
                app:cornerRadius="30dp"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>