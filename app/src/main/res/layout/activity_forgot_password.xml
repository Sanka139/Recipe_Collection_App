<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark_main">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/img6" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reset Password"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter new credentials to securely log in"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="40dp"/>

        <EditText
            android:id="@+id/etResetIdentity"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Username or Email"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_glass_edittext"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/etNewPassword"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="New Password"
            android:inputType="textPassword"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_glass_edittext"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/etConfirmNewPassword"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Re-enter New Password"
            android:inputType="textPassword"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_glass_edittext"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnConfirmReset"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="UPDATE PASSWORD"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/accent_orange"
            android:textColor="@color/text_primary"
            app:cornerRadius="30dp"/>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>