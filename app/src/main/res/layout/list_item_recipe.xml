<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_glass_edittext"> <TextView
    android:id="@+id/tvRowRecipeName"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Recipe Name Here"
    android:textColor="#FFFFFF" android:textSize="20sp"
    android:textStyle="bold" />

    <TextView
        android:id="@+id/tvRowTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Time: 30 Mins"
        android:textColor="#A0A0A0" android:textSize="14sp" />

</LinearLayout>