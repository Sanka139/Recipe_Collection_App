<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="12dp"
    android:gravity="center_vertical"
    android:background="@drawable/bg_glass_edittext">

    <androidx.cardview.widget.CardView
        android:layout_width="70dp"
        android:layout_height="70dp"
        app:cardCornerRadius="12dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">
        <ImageView
            android:id="@+id/ivRowImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/img3" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="16dp">

        <TextView
            android:id="@+id/tvRowRecipeName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recipe Name"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRowTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="30 Mins"
            android:textColor="#A0A0A0"
            android:textSize="14sp" />
    </LinearLayout>
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_glass_edittext"> <TextView
    android:id="@+id/tvRowRecipeName"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Recipe Name Here"
    android:textColor="#FFFFFF" android:textSize="20sp"
    android:textStyle="bold" />

    <TextView
        android:id="@+id/tvRowTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Time: 30 Mins"
        android:textColor="#A0A0A0" android:textSize="14sp" />

</LinearLayout>